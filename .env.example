# Copy to `.env` and fill in real values. Do not commit `.env`.
#
# Conversation persistence (chat history + checkpoints)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME"

# Alternative (recommended when passwords contain special characters): build DSN from parts.
# If MERIDIAN_PG_HOST + MERIDIAN_PG_PASSWORD are set, they take precedence over DATABASE_URL.
# MERIDIAN_PG_HOST="db.<project-ref>.supabase.co"
# MERIDIAN_PG_USER="postgres"
# MERIDIAN_PG_DB="postgres"
# MERIDIAN_PG_PORT="5432"
# MERIDIAN_PG_SSLMODE="require"
# MERIDIAN_PG_PASSWORD="plain-text password (no URL encoding needed)"
#
# Data source for deals/reps (optional; defaults to CSV)
# MERIDIAN_DATA_SOURCE=postgres
# MERIDIAN_DATA_DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME"
#
# Optional LLM routing for paraphrases
# OPENAI_API_KEY="..."
# MERIDIAN_ENABLE_LLM_ROUTER=1
# MERIDIAN_ROUTER_MODEL="gpt-4o-mini"
